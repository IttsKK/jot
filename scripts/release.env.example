# Copy this file to scripts/release.env and customize values.

# GitHub owner and repo used for Sparkle appcast download URLs.
REPO_OWNER=IttsKK
REPO_NAME=jot

# For local testing/distribution, keep ad-hoc signing:
SIGN_IDENTITY=-

# Sparkle keychain account used by generate_keys / generate_appcast.
SPARKLE_KEY_ACCOUNT=ed25519
# Optional: direct private key file path for generate_appcast.
# SPARKLE_ED_KEY_FILE=/absolute/path/to/private_ed25519_key
# Optional: private key string from env (highest priority over keychain/file).
# SPARKLE_PRIVATE_KEY=

# Optional DMG presentation tweaks.
# DMG_BACKGROUND is auto-detected from Jot/Resources/DMG/background.png if present.
# DMG_BACKGROUND=$ROOT_DIR/Jot/Resources/DMG/background.png
# DMG_TOOL=auto
# DMG_ICON_SIZE=128  (default)

# Optional app/dmg icon files (.icns).
# APP_ICON_ICNS=/Users/caelan/Documents/Development/jot/Jot/Resources/AppIcon.icns
# APP_ICON_LIGHT_ICNS=/Users/caelan/Documents/Development/jot/Jot/Resources/AppIconLight.icns
# APP_ICON_DARK_ICNS=/Users/caelan/Documents/Development/jot/Jot/Resources/AppIconDark.icns
# DMG_VOLUME_ICON_ICNS=/Users/caelan/Documents/Development/jot/Jot/Resources/AppIcon.icns

# Optional themed icon asset catalog for CFBundleIconName/AppIcon.
# ASSETS_CATALOG=/Users/caelan/Documents/Development/jot/Jot/Resources/Assets.xcassets

# Optional defaults you can override per run.
# VERSION=1.0.0
# BUILD_NUMBER=1
# RELEASE_TAG=v1.0.0
